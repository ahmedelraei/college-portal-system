              "mode": "raw",
              "raw": "{\n  \"cardNumber\": \"4111111111111111\",\n  \"expiryDate\": \"12/25\",\n  \"cvv\": \"123\",\n  \"cardholderName\": \"John Doe\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/{{paymentId}}/process",
