            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane.updated@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/students/{{studentId}}",
            "description": "Update a student. Admin only."
