        {
          "name": "Delete Student (Admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/students/{{studentId}}",
            "description": "Delete a student. Admin only."
          }
        }
      ]
    },
    {
      "name": "Courses",
