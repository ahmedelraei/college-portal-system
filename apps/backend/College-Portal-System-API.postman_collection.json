            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseCode\": \"CS101\",\n  \"courseName\": \"Introduction to Programming\",\n  \"description\": \"Basic programming concepts\",\n  \"creditHours\": 3,\n  \"pricePerCredit\": 500,\n  \"semester\": \"summer\",\n  \"prerequisiteIds\": []\n}"
            },
            "url": "{{baseUrl}}/api/courses",
            "description": "Create a course. semester: summer | winter. Admin only."
