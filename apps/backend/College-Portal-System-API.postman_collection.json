          "name": "Find All Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses?semester=summer&search=CS&creditHours=3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"],
              "query": [
                {"key": "semester", "value": "summer", "disabled": true},
                {"key": "search", "value": "CS", "disabled": true},
                {"key": "creditHours", "value": "3", "disabled": true}
